{
  "expo": {
    "name": "Vardiya Planı",
    "slug": "vardiya-plani",
    "version": "1.2.4",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "vardiyaplani",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.demrivo.vardiyaplani",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.demrivo.vardiyaplani",
      "versionCode": 17,
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0B1026"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon2.png",
          "resizeMode": "contain",
          "backgroundColor": "#0B1026",
          "imageWidth": 200
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9db300d9-669f-474f-98cf-4d9184605880"
      },
      "router": {}
    }
  }
}
